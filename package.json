{
  "name": "licop",
  "version": "1.0.1",
  "type": "module",
  "description": "Scan npm dependencies for risky licenses",
  "bin": {
    "licop": "dist/bin/licop.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "docs/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "dev": "vitest --watch",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "lint": "eslint ./src --ext .ts",
    "start": "node dist/bin/licop.js",
    "licop": "licop",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "license",
    "cli",
    "npm",
    "dependencies",
    "scanner",
    "audit",
    "risk",
    "compliance",
    "open-source"
  ],
  "author": "Chrilleweb",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Chrilleweb/licop.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/Chrilleweb/licop#readme",
  "bugs": {
    "url": "https://github.com/Chrilleweb/licop/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "release-it": "^20.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  }
}
